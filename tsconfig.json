{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "strict": true,
    "target": "ESNext",
    "module": "commonjs",
    "lib": [
      "ESNext"
    ],
    "types": [
      "jest",
      "@types/react"
    ],
    "jsx": "react-native",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "jest-setup.js",
    "jest.config.js"
  ],
  "exclude": [
    "node_modules"
  ],
  "extends": "expo/tsconfig.base"
}
